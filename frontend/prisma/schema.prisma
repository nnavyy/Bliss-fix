generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")   // prisma:// URL — untuk Prisma Client (Accelerate)
  directUrl = env("DIRECT_URL")     // postgresql:// URL — untuk migrations & prisma db push
}

model Doctor {
  doctorId  String   @id
  token     String
  createdAt DateTime @default(now())

  scans Scan[]
}

model Scan {
  id          String   @id @default(uuid())
  patientName String
  image       String   // base64 data URL
  result      String   // "Batu Ginjal" | "Normal"
  confidence  Float
  predictions Json     // raw predictions dari Roboflow
  scannedAt   DateTime @default(now())

  doctorId String
  doctor   Doctor @relation(fields: [doctorId], references: [doctorId])
}
